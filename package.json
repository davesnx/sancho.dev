    "clean": "rimraf .next out",
    "ts": "tsc --noEmit --pretty",
    "format": "biome format --write src scripts --config-path biome.json",
    "lint": "biome lint --write src scripts --config-path biome.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mdx-js/loader": "^3.1.1",
