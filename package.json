    "@next/mdx": "^16.2.2",
    "@babel/runtime": "^7.28.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wyw-in-js/babel-preset": "^1.0.7",
    "@wyw-in-js/transform": "^1.0.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "effect": "^3.21.0",
    "esbuild": "^0.28.0",
    "globby": "^16.2.0",
    "gray-matter": "^4.0.3",
    "@linaria/core": "^7.0.0",
    "@linaria/react": "^7.0.1",
    "next": "^16.2.2",
    "next-with-linaria": "^1.3.0",
    "next-themes": "^0.4.6",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "rimraf": "^6.1.3",
